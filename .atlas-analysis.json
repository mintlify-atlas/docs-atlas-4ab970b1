  "keyFeatures": [
    "AI-optimized output formats (XML, Markdown, JSON, Plain Text)",
    "Token counting for LLM context limits",
    "Git-aware file filtering (.gitignore, .ignore)",
    "Built-in security scanning with Secretlint",
    "Code compression using Tree-sitter",
    "Remote repository processing",
    "Model Context Protocol (MCP) server",
    "Browser extension for GitHub",
    "Claude Code plugins",
    "Agent Skills generation",
    "File splitting for large codebases"
  ],
  "publicApiSurface": [
    "repomix [directories...] - Main CLI command",
    "repomix --init - Initialize configuration",
    "repomix --remote <url> - Process remote repository",
    "repomix --mcp - Run as MCP server",
    "repomix --compress - Enable code compression",
    "repomix --style <format> - Set output format",
    "repomix --include <patterns> - Include files",
    "repomix --ignore <patterns> - Exclude files",
    "repomix --output <file> - Set output file",
    "repomix --skill-generate - Generate Agent Skills",
    "pack() - Programmatic API function",
    "collectFiles() - File collection API",
    "runSecurityCheck() - Security validation API",
    "TokenCounter - Token counting class"
  ]
